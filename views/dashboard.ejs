<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Dashboard - FreelanceHQ</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50">
  <div class="max-w-7xl mx-auto p-8">
    <h1 class="text-4xl font-bold">Welcome back, John!</h1>
    <p class="text-gray-600 mt-2">Manage your projects with ease.</p>

    <!-- Stats -->
    <div class="grid grid-cols-4 gap-6 mt-10">
      <div class="bg-white p-6 rounded-3xl">Active Projects: <span class="font-bold text-3xl block">2</span></div>
      <div class="bg-white p-6 rounded-3xl">Pending Bids: <span class="font-bold text-3xl block">5</span></div>
      <div class="bg-white p-6 rounded-3xl">Completed: <span class="font-bold text-3xl block">12</span></div>
      <div class="bg-white p-6 rounded-3xl">$1,250.00</div>
    </div>

    <a href="/login" class="mt-10 inline-block bg-blue-600 text-white px-8 py-4 rounded-2xl">Back to Login</a>
  </div>
</body>
</html>